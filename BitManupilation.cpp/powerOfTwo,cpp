#include<iostream>
using namespace std;
bool isPowerOfTwo(int n){
    if(n==0){
        return false;
    }
    else if((n&(n-1))==0){
        return true;
    }

    return false;
}
int main(){
    int n;
    cin>>n;
    if(isPowerOfTwo(n)==true){
         cout<<"The number is power of two"<<endl;
    }
    else{
        cout<<"The number is not power of two"<<endl;
    }
}